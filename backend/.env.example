# SAAITA backend environment template
# Copy to backend/.env and replace placeholder values.

# Runtime environment: development | staging | production
ENVIRONMENT=development

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://saaita_user:change_this_password@localhost:5432/saaita

# JWT signing key (minimum 32 chars)
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=replace_with_generated_jwt_secret

# Redis URL for rate limiting and queues
REDIS_URL=redis://localhost:6379/0

# Gemini API key used by AI chat
GEMINI_API_KEY=replace_with_gemini_api_key

# Frontend origins allowed to call backend APIs
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# SMTP provider settings used for verification and password reset emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=replace_with_smtp_app_password
EMAIL_FROM=noreply@saaita.local

# Public app URL used in email links
APP_URL=http://localhost:5173

# Request size limits (bytes)
MAX_JSON_SIZE=1048576
MAX_FILE_SIZE=5242880
