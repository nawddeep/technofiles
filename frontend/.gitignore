# Dependencies — never commit
node_modules/

# Build output — generated, not source
dist/
dist-ssr/
*.local

# Environment variables — NEVER commit real .env
.env
.env.local
.env.*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS files
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
